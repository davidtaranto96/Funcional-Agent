# Twilio (WhatsApp Business)
# Obtener en: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=          # Empieza con AC...
TWILIO_AUTH_TOKEN=           # Token secreto de tu cuenta
TWILIO_WHATSAPP_NUMBER=      # Tu número de WhatsApp en formato whatsapp:+14155238886

# OpenAI (Whisper)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Resend (emails)
RESEND_API_KEY=
RESEND_FROM=WPanalista <onboarding@resend.dev>

# David (notificaciones)
DAVID_PHONE=whatsapp:+549XXXXXXXXXX
DAVID_EMAIL=david@example.com

# Server
PORT=3000

# URL pública de la app (para armar links de demos y review)
APP_URL=http://localhost:3000

# Admin dashboard (/admin)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
# Token compartido para endpoints HTTP no-browser: /context, /reset, /start, /webhook/debug, /webhook/last, /webhook/test-groq
# Pasalo como header `x-admin-token: <valor>` o query `?admin_token=<valor>`
ADMIN_API_TOKEN=

# Google Drive (Service Account) — opcional
# 1. Crear Service Account en Google Cloud Console
# 2. Bajar JSON de credenciales
# 3. Convertir a base64:  cat creds.json | base64 -w 0
# 4. Crear carpeta en Drive, compartirla con el email del service account, copiar folder ID
GOOGLE_DRIVE_CREDENTIALS=
GOOGLE_DRIVE_PARENT_FOLDER_ID=

# Google Calendar — para agendar reuniones automáticamente
# 1. En Google Cloud Console → APIs & Services → habilitar "Google Calendar API"
# 2. En Credenciales → tu OAuth 2.0 Client ID → agregar redirect URI: http://localhost:3001/callback
# 3. Copiar Client ID y Client Secret acá abajo
# 4. Correr: node scripts/get-google-token.js
# 5. Pegar el GOOGLE_REFRESH_TOKEN que aparece en la terminal
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
