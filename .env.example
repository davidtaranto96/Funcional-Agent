# Meta Cloud API (WhatsApp Business)
# Obtener en: developers.facebook.com → tu app → WhatsApp → Configuración de API
META_PHONE_NUMBER_ID=        # ID del número de teléfono (no el número en sí)
META_ACCESS_TOKEN=           # Token de acceso permanente de System User
META_VERIFY_TOKEN=           # String que vos elegís para verificar el webhook

# OpenAI (Whisper)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Resend (emails)
RESEND_API_KEY=
RESEND_FROM=WPanalista <onboarding@resend.dev>

# David (notificaciones)
DAVID_PHONE=whatsapp:+549XXXXXXXXXX
DAVID_EMAIL=david@example.com

# Server
PORT=3000

# URL pública de la app (para armar links de demos y review)
APP_URL=http://localhost:3000

# Admin dashboard (/admin)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Google Drive (Service Account) — opcional
# 1. Crear Service Account en Google Cloud Console
# 2. Bajar JSON de credenciales
# 3. Convertir a base64:  cat creds.json | base64 -w 0
# 4. Crear carpeta en Drive, compartirla con el email del service account, copiar folder ID
GOOGLE_DRIVE_CREDENTIALS=
GOOGLE_DRIVE_PARENT_FOLDER_ID=
