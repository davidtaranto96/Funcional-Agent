# Copiá este archivo a .env.local y completá los valores.
# El web/ comparte la mayoría con la raíz — se pueden duplicar.

# ─── Auth ─────────────────────────────────────────────────────────────
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=                 # mínimo 32 chars random — `openssl rand -hex 32`
ADMIN_API_TOKEN=                      # token compartido para /api/context, /api/reset, /api/start
ADMIN_ALLOWED_EMAILS=                 # opcional: emails separados por coma para Google OAuth

# ─── Twilio (WhatsApp) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# ─── LLMs ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ─── Email ────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=WPanalista <onboarding@resend.dev>

# ─── Notificaciones a David ──────────────────────────────────────────
DAVID_PHONE=whatsapp:+549XXXXXXXXXX
DAVID_EMAIL=david@example.com

# ─── DB (Turso/libsql) ────────────────────────────────────────────────
# Dejar vacío → usa SQLite local en ../data/conversations.db (compartido con el legacy Express)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ─── App URL pública ─────────────────────────────────────────────────
APP_URL=http://localhost:3000

# ─── Google (OAuth + Calendar + Drive) ───────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_CREDENTIALS=
GOOGLE_DRIVE_PARENT_FOLDER_ID=
